# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=vk_downloader_bot

# ==================== TELEGRAM LOCAL BOT API ====================
# Нужны для Local Bot API — файлы до 2 ГБ (VK-видео часто > 50 МБ).
# Получить на https://my.telegram.org
API_ID=
API_HASH=

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_vk
DB_USER=bot_4_vk
DB_PASSWORD=

# ==================== АДМИНЫ ====================

ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== КЭШ ====================

CACHE_TTL_DAYS=1

# ==================== VK — опционально ====================

# Прокси для скачивания (SOCKS5/HTTP). Нужен если бот запущен не в РФ
# и VK отвечает гео-блоком. Для РФ-VPS можно оставить пустым.
# Формат: socks5://user:pass@host:port  или  http://host:port
# PROXY_URL=

# Cookies для приватных/18+/сторис-контента.
# Положи экспортированные cookies в ./cookies/cookies.txt (см. README).
# Если файла нет — бот просто не использует этот fallback.
